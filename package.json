{
  "name": "whatsapp4etc",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard multi-número WhatsApp - Atendimento profissional",
  "scripts": {
    "dev:web": "npm --prefix web run dev",
    "dev:api": "npm --prefix api run start:dev",
    "build:web": "npm --prefix web run build",
    "build:api": "npm --prefix api run build",
    "install:all": "npm install && npm --prefix web install && npm --prefix api install"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
