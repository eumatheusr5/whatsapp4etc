# ===== Supabase (back e front) =====
SUPABASE_URL=https://ioadobjuizywerkglqjy.supabase.co
SUPABASE_ANON_KEY=
# Apenas no backend (Render). NUNCA expor no frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ===== Backend (Render) =====
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
# Domínio do frontend (CORS)
WEB_ORIGIN=https://whatsapp4etc.vercel.app

# ===== Redis (BullMQ - Render Key Value) =====
REDIS_URL=redis://default:senha@host:6379

# ===== Transcrição de áudio =====
GROQ_API_KEY=
# Fallback opcional caso Groq atinja limite
OPENAI_API_KEY=

# ===== Web Push (VAPID) =====
# Gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@empresa.com.br

# ===== Sentry =====
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=

# ===== Frontend (Vercel) =====
VITE_SUPABASE_URL=https://ioadobjuizywerkglqjy.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=https://whatsapp4etc-api.onrender.com
VITE_VAPID_PUBLIC_KEY=
VITE_SENTRY_DSN=
